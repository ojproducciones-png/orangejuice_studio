# API de Anthropic (Claude)
# Consíguelo en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Token de acceso de Meta (WhatsApp Business API)
# Lo obtienes en: Meta for Developers > tu app > WhatsApp > API Setup
WHATSAPP_TOKEN=EAAxxxxxxx...

# Token de verificación del webhook (puedes inventar cualquier string seguro)
# Ejemplo: oj-studio-webhook-2026
WHATSAPP_VERIFY_TOKEN=tu-token-secreto-aqui
